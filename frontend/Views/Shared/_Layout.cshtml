<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/frontend.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column mb-0" style="height: fit-content;">
    @using Microsoft.AspNetCore.Http
    @inject IHttpContextAccessor HttpContextAccessor
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="Zyuuki Music" />
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
                        aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="GioiThieu">Giới thiệu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="SanPham" asp-action="Index">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="DanhGia">Đánh giá</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3 flex-column flex-lg-row mt-3 mt-lg-0">

                        <form class="d-flex search-group" method="post" asp-controller="SanPham" asp-action="timKiem">
                            <div class="input-group">
                                <input class="form-control" type="search" name="keyword" placeholder="Tìm nhạc cụ..." aria-label="Search">
                                <button class="btn btn-search" type="submit"><i class="bi bi-search"></i></button>
                            </div>
                        </form>

                        <div class="d-none d-xl-block text-end lh-1">
                            <small class="text-muted" style="font-size: 0.7rem;">Hotline 24/7</small><br />
                            <span class="fw-bold text-dark">0869 347 040</span>
                        </div>

                        <form method="post" asp-controller="DonDatHang" asp-action="Index">
                            <button class="btn-cart-wrapper" type="submit">
                                <i class="bi bi-cart3"></i>

                                <span class="cart-badge-count">
                                    @await Component.InvokeAsync("DemGioHang")
                                </span>
                            </button>
                        </form>

                        <div class="user-menu">
                            @if (HttpContextAccessor.HttpContext.Session.GetString("UserEmail") == null)
                            {
                                <form method="get" asp-controller="TaiKhoan" asp-action="DangNhap">
                                    <button class="btn btn-login btn-outline-dark rounded-pill px-4" type="submit">
                                        <i class="bi bi-person me-1"></i> Đăng Nhập
                                    </button>
                                </form>
                            }
                            else
                            {
                                string userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole") ?? "";
                                <div class="dropdown">
                                    <a class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-person-circle fs-5 me-2"></i>
                                        <span class="fw-semibold">@HttpContextAccessor.HttpContext.Session.GetString("UserName")</span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                        <li>
                                            <a class="dropdown-item" asp-controller="TaiKhoan" asp-action="XemTaiKhoan" asp-route-email="@HttpContextAccessor.HttpContext.Session.GetString("UserEmail")">
                                                <i class="bi bi-person-vcard me-2"></i> Hồ sơ cá nhân
                                            </a>
                                        </li>
                                        @if (userRole == "Admin" || userRole == "Staff")
                                        {
                                            <li>
                                                <a class="dropdown-item" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                                    <i class="bi bi-speedometer2 me-2"></i> Quản trị hệ thống
                                                </a>
                                            </li>
                                        }
                                        else if (userRole == "Carrier")
                                        {
                                            <li>
                                                <a class="dropdown-item" asp-area="Carrier" asp-controller="Home" asp-action="Index">
                                                    <i class="bi bi-truck me-2"></i> Quản lý vận chuyển
                                                </a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li>
                                                <a class="dropdown-item" asp-controller="TaiKhoan" asp-action="lichSuDDH" asp-route-id="@HttpContextAccessor.HttpContext.Session.GetInt32("UserId")">
                                                    <i class="bi bi-clock-history me-2"></i> Lịch sử đơn hàng
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" asp-controller="TaiKhoan" asp-action="xemSanPham" asp-route-id="@HttpContextAccessor.HttpContext.Session.GetInt32("UserId")">
                                                    <i class="bi bi-box-seam me-2"></i> Sản phẩm đã mua
                                                </a>
                                            </li>
                                        }
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger" asp-controller="TaiKhoan" asp-action="DangXuat">
                                                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="pt-5 pb-3 zyuuki-footer">
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="text-warning mb-3 fw-bold">Về Zyuuki Music</h5>
                    <p class="small text-light" style="line-height: 1.6;">
                        Chúng tôi chuyên cung cấp các loại nhạc cụ Piano, Guitar, Violin chính hãng với giá tốt nhất thị trường cùng chế độ bảo hành uy tín.
                    </p>
                    <div class="mt-4">
                        <a href="#" class="footer-social-link me-2"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="footer-social-link me-2"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="footer-social-link"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <h5 class="text-warning mb-3 fw-bold">Thông Tin Liên Hệ</h5>
                    <ul class="list-unstyled small" style="line-height: 2;">
                        <li class="d-flex align-items-start mb-2">
                            <i class="bi bi-geo-alt-fill text-warning me-3 mt-1"></i>
                            <span>180 Cao Lỗ, Phường 4, Quận 8, TP.HCM</span>
                        </li>
                        <li class="d-flex align-items-center mb-2">
                            <i class="bi bi-telephone-fill text-warning me-3"></i>
                            <span>0869 347 040</span>
                        </li>
                        <li class="d-flex align-items-center mb-2">
                            <i class="bi bi-envelope-fill text-warning me-3"></i>
                            <span>dh52200473@student.stu.edu.vn</span>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-12">
                    <h5 class="text-warning mb-3 fw-bold">Đội Ngũ Thực Hiện</h5>
                    <div class="row g-2 border-start border-secondary border-opacity-50 ps-3">
                        <div class="col-6 mb-2">
                            <div class="team-member-name fw-semibold">Lê Văn Đạt</div>
                            <div class="team-member-id">DH52200473</div>
                        </div>
                        <div class="col-6 mb-2">
                            <div class="team-member-name fw-semibold">Nguyễn Thanh Sang</div>
                            <div class="team-member-id">DH52201360</div>
                        </div>
                        <div class="col-6 mb-2">
                            <div class="team-member-name fw-semibold">Kheo Hoàng Trung</div>
                            <div class="team-member-id">DH52201668</div>
                        </div>
                        <div class="col-6 mb-2">
                            <div class="team-member-name fw-semibold">Nguyễn Ngọc Trung Quý</div>
                            <div class="team-member-id">DH52201331</div>
                        </div>
                        <div class="col-6 mb-0">
                            <div class="team-member-name fw-semibold">Nguyễn Hồ Phúc Thịnh</div>
                            <div class="team-member-id">DH52201498</div>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="border-secondary mt-4 mb-3 opacity-25" />
            <div class="text-center small text-secondary">
                &copy; 2026 - <strong class="text-light">Zyuuki Music Store</strong>. All rights reserved.
            </div>
        </div>
    </footer>
</body>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</html>
